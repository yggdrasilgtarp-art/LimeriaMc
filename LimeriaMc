<script>
function showSection(section){
const sections=document.querySelectorAll('.section');
sections.forEach(s=>s.classList.remove('active'));
document.getElementById(section).classList.add('active');
}

function copyIP(){
navigator.clipboard.writeText('play.tonserveur.fr');
alert('IP copiée : play.tonserveur.fr');
}

function buy(credits){
let user=document.getElementById('username').value;
if(!user){
alert('Entre ton pseudo Minecraft');
return;
}

/* Tebex checkout link (à remplacer par ton vrai store Tebex) */
let url="https://tonserveur.tebex.io/?ign="+user+"&package="+credits;
window.open(url,'_blank');
}

function vote(url){
